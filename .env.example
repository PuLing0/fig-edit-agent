# LLM
LLM_BASE_URL="https://api.openai.com/v1"
LLM_MODEL_NAME="gpt-4o-mini"
LLM_API_KEY="your_api_key_here"

# SAM3
SAM3_REPO_PATH="/absolute/path/to/your/local/sam3/repo"
SAM3_CHECKPOINT_PATH="/absolute/path/to/your/local/sam3.1_multiplex.pt"
SAM3_LOAD_FROM_HF=false
SAM3_MODEL_VERSION="sam3.1"

# GPU / runtime
SAM3_DEVICE="cuda"
SAM3_CUDA_VISIBLE_DEVICES="0"
SAM3_COMPILE=false
