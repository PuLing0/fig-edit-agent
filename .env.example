# LLM
LLM_BASE_URL="https://api.openai.com/v1"
LLM_MODEL_NAME="gpt-4o-mini"
LLM_API_KEY="your_api_key_here"

# SAM3
SAM3_REPO_PATH="/absolute/path/to/your/local/sam3/repo"
SAM3_CHECKPOINT_PATH="/absolute/path/to/your/local/sam3.1_multiplex.pt"
SAM3_LOAD_FROM_HF=false
SAM3_MODEL_VERSION="sam3.1"

# GPU / runtime
SAM3_DEVICE="cuda"
SAM3_CUDA_VISIBLE_DEVICES="0"
SAM3_COMPILE=false

# FireRed image edit backend
FIRERED_MODEL_PATH="FireRedTeam/FireRed-Image-Edit-1.0"
FIRERED_INFERENCE_MODE="normal"
FIRERED_LOCAL_FILES_ONLY=false
FIRERED_CUDA_VISIBLE_DEVICES="0"
FIRERED_DEVICE_MAP=""
FIRERED_PER_GPU_MAX_MEMORY=""
FIRERED_CPU_MAX_MEMORY="128GiB"
FIRERED_GENERATOR_DEVICE="auto"
FIRERED_ENABLE_ATTENTION_SLICING=false
FIRERED_LORA_PATH=""
FIRERED_LORA_WEIGHT_NAME=""
FIRERED_LORA_ADAPTER_NAME="demo"
FIRERED_FUSE_LORA=false
FIRERED_NUM_INFERENCE_STEPS=40
FIRERED_TRUE_CFG_SCALE=4.0
FIRERED_GUIDANCE_SCALE=1.0
FIRERED_NEGATIVE_PROMPT=" "
FIRERED_SEED=49
